# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://focusmeet:focusmeet@postgres:5432/focusmeet
DATABASE_URL_SYNC=postgresql://focusmeet:focusmeet@postgres:5432/focusmeet

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT / Auth ──────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_INVITE_EXPIRE_MINUTES=15

# ─── LiveKit ─────────────────────────────────────────────
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_URL=ws://localhost:7880

# ─── App ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DEBUG=true

# ─── Engagement Engine ─────────────────────────────────────
ENGAGEMENT_SAMPLE_INTERVAL_SEC=10
ENGAGEMENT_WINDOW_SEC=30
ENGAGEMENT_CHECK_INTERVAL_SEC=30
LOW_ENGAGEMENT_THRESHOLD=40.0
LOW_ENGAGEMENT_CONSECUTIVE=2

# ─── AI Moderation ─────────────────────────────────────────
MODERATION_TOXIC_THRESHOLD=0.7
MODERATION_WHISPER_MODEL=base
MODERATION_WHISPER_DEVICE=cpu
MODERATION_WHISPER_COMPUTE_TYPE=int8
MODERATION_ENABLED=true

# ─── AI Meeting Summarizer (Local Ollama) ──────────────────
# When running in Docker and Ollama runs on your Windows/Mac host, use:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_TIMEOUT_SECONDS=180
